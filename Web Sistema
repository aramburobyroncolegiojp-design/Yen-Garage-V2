<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Yen Garage — Control Operativo</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ===================== RESET + ROOT ===================== */
:root {
  --bg: #f2ede4;
  --surface: #ffffff;
  --surface2: #e8e2d8;
  --border: #cec9bf;
  --ink: #1a1a1a;
  --muted: #7a7870;
  --accent: #c1440e;
  --green: #1a6b3c;
  --yellow: #c98a10;
  --blue: #1a3a6b;
  --red: #c1440e;
  --nav-h: 64px;
  --header-h: 56px;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
width: 100%;
max-width: 100%;
overflow-x: hidden;
background: var(–bg);
color: var(–ink);
font-family: ‘IBM Plex Mono’, monospace;
font-size: 14px;
-webkit-font-smoothing: antialiased;
}

/* ===================== LAYOUT SHELL ===================== */
.app {
width: 100%;
max-width: 480px;
margin: 0 auto;
min-height: 100dvh;
display: flex;
flex-direction: column;
position: relative;
overflow: hidden;
}

/* ===================== HEADER ===================== */
.app-header {
width: 100%;
background: var(–ink);
border-bottom: 3px solid var(–accent);
padding: 0 16px;
height: var(–header-h);
display: flex;
align-items: center;
justify-content: space-between;
flex-shrink: 0;
position: sticky;
top: 0;
z-index: 100;
}

.brand {
font-family: ‘Bebas Neue’, cursive;
font-size: 22px;
letter-spacing: 3px;
color: #f2ede4;
line-height: 1;
}

.brand span { color: var(–accent); }

.header-badge {
background: var(–accent);
color: #fff;
font-family: ‘Bebas Neue’, cursive;
font-size: 11px;
letter-spacing: 2px;
padding: 3px 8px;
}

/* ===================== SCROLL AREA ===================== */
.scroll-area {
flex: 1;
overflow-y: auto;
overflow-x: hidden;
padding-bottom: calc(var(–nav-h) + 12px);
-webkit-overflow-scrolling: touch;
}

/* ===================== PAGES ===================== */
.page { display: none; padding: 16px; }
.page.active { display: block; }

/* ===================== BOTTOM NAV ===================== */
.bottom-nav {
position: fixed;
bottom: 0;
left: 50%;
transform: translateX(-50%);
width: 100%;
max-width: 480px;
height: var(–nav-h);
background: var(–ink);
border-top: 2px solid #2a2a2a;
display: flex;
align-items: stretch;
z-index: 200;
}

.nav-btn {
flex: 1;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 3px;
background: transparent;
border: none;
cursor: pointer;
border-top: 3px solid transparent;
transition: all 0.15s;
padding: 6px 0;
position: relative;
}

.nav-btn.active { border-top-color: var(–accent); }

.nav-icon { font-size: 11px; line-height: 1; font-family: ‘Bebas Neue’, cursive; letter-spacing: 1px; color: #555; }
.nav-btn.active .nav-icon { color: #f2ede4; }

.nav-label {
font-family: ‘Bebas Neue’, cursive;
font-size: 10px;
letter-spacing: 2px;
color: #555;
transition: color 0.15s;
}

.nav-btn.active .nav-label { color: #f2ede4; }

.nav-badge {
position: absolute;
top: 6px; right: 20%;
background: var(–accent);
color: #fff;
font-size: 8px;
font-family: ‘Bebas Neue’, cursive;
padding: 1px 4px;
min-width: 14px;
text-align: center;
line-height: 1.4;
}

/* ===================== SHARED COMPONENTS ===================== */
.section-title {
font-family: ‘Bebas Neue’, cursive;
font-size: 16px;
letter-spacing: 2px;
border-bottom: 2px solid var(–ink);
padding-bottom: 6px;
margin-bottom: 14px;
display: flex;
align-items: baseline;
justify-content: space-between;
}

.section-sub {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 8px;
font-weight: 300;
letter-spacing: 1px;
color: var(–muted);
text-transform: uppercase;
}

.card {
background: var(–surface);
border: 1px solid var(–border);
padding: 16px;
margin-bottom: 12px;
}

.field-group {
display: flex;
flex-direction: column;
gap: 4px;
margin-bottom: 10px;
}

.field-label {
font-size: 8px;
text-transform: uppercase;
letter-spacing: 2px;
color: var(–muted);
}

.req { color: var(–accent); }

.field-input, .field-select {
width: 100%;
background: var(–bg);
border: 1px solid var(–border);
border-bottom: 2px solid var(–ink);
padding: 9px 10px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 13px;
color: var(–ink);
outline: none;
-webkit-appearance: none;
appearance: none;
border-radius: 0;
transition: border-color 0.15s;
}

.field-input:focus, .field-select:focus { border-bottom-color: var(–accent); }

.grid-2 {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
}

/* ===================== COST ROWS ===================== */
.cost-section-label {
font-size: 8px;
text-transform: uppercase;
letter-spacing: 2px;
color: var(–accent);
background: rgba(193,68,14,0.07);
padding: 5px 10px;
border-left: 3px solid var(–accent);
margin: 10px 0 6px;
}

.cost-row {
display: grid;
grid-template-columns: 1fr 80px 70px 24px;
gap: 6px;
align-items: center;
padding: 6px 0;
border-bottom: 1px dashed var(–border);
}

.cost-row:last-child { border-bottom: none; }

.cost-col-headers {
display: grid;
grid-template-columns: 1fr 80px 70px 24px;
gap: 6px;
padding: 4px 0 6px;
border-bottom: 1px solid var(–ink);
margin-bottom: 4px;
}

.col-h {
font-size: 8px;
text-transform: uppercase;
letter-spacing: 1px;
color: var(–muted);
text-align: right;
}

.col-h:first-child { text-align: left; }

.cost-name { font-size: 11px; }

.cost-input {
width: 100%;
background: var(–bg);
border: 1px solid var(–border);
padding: 5px 7px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 11px;
color: var(–ink);
outline: none;
text-align: right;
border-radius: 0;
-webkit-appearance: none;
}

.cost-input:focus { border-color: var(–accent); }

.cost-subtotal {
font-size: 11px;
font-weight: 600;
text-align: right;
}

.del-btn {
background: transparent;
border: none;
color: var(–border);
font-size: 16px;
cursor: pointer;
padding: 2px;
line-height: 1;
transition: color 0.15s;
}

.del-btn:hover, .del-btn:active { color: var(–accent); }

.add-row-btn {
width: 100%;
background: transparent;
border: 1px dashed var(–border);
color: var(–muted);
padding: 6px 10px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 9px;
text-transform: uppercase;
letter-spacing: 1px;
cursor: pointer;
text-align: left;
margin-top: 4px;
transition: all 0.15s;
border-radius: 0;
}

.add-row-btn:active { border-color: var(–accent); color: var(–accent); }

/* ===================== PRICE BOX ===================== */
.precio-box {
background: var(–ink);
padding: 16px;
text-align: center;
margin-bottom: 12px;
}

.precio-label {
font-size: 8px;
text-transform: uppercase;
letter-spacing: 3px;
color: #666;
margin-bottom: 6px;
}

.precio-value {
font-family: ‘Bebas Neue’, cursive;
font-size: 48px;
letter-spacing: 2px;
color: #f2ede4;
line-height: 1;
}

.precio-value span { color: var(–accent); }
.precio-sub { font-size: 9px; color: #666; margin-top: 4px; }

/* ===================== MARGEN BAR ===================== */
.margen-bar-wrap {
background: var(–surface2);
border: 1px solid var(–border);
height: 20px;
margin: 10px 0;
position: relative;
overflow: hidden;
}

.margen-bar {
height: 100%;
background: var(–green);
transition: width 0.5s ease;
}
.margen-bar.w { background: var(–yellow); }
.margen-bar.d { background: var(–red); }

.margen-label {
position: absolute;
right: 8px; top: 50%;
transform: translateY(-50%);
font-size: 10px;
font-weight: 600;
color: var(–ink);
}

/* ===================== VEREDICTO ===================== */
.veredicto {
padding: 20px 16px;
text-align: center;
border: 3px solid var(–ink);
transition: all 0.3s;
margin-bottom: 12px;
}
.veredicto.rentable { background: var(–green); border-color: var(–green); color: #fff; }
.veredicto.warning { background: var(–yellow); border-color: var(–yellow); color: var(–ink); }
.veredicto.perdida { background: var(–red); border-color: var(–red); color: #fff; }

.v-icon { display: none; }
.v-title { font-family: ‘Bebas Neue’, cursive; font-size: 28px; letter-spacing: 3px; line-height: 1; }
.v-sub { font-size: 10px; margin-top: 5px; opacity: 0.85; letter-spacing: 0.5px; }

/* ===================== BUTTONS ===================== */
.btn-row { display: flex; gap: 8px; margin-top: 12px; }

.btn-primary {
flex: 1;
background: var(–ink);
color: #f2ede4;
border: none;
padding: 13px 16px;
font-family: ‘Bebas Neue’, cursive;
font-size: 15px;
letter-spacing: 2px;
cursor: pointer;
transition: background 0.15s;
border-radius: 0;
-webkit-appearance: none;
}
.btn-primary:active { background: var(–accent); }

.btn-secondary {
background: transparent;
color: var(–ink);
border: 2px solid var(–ink);
padding: 11px 14px;
font-family: ‘Bebas Neue’, cursive;
font-size: 14px;
letter-spacing: 2px;
cursor: pointer;
transition: all 0.15s;
border-radius: 0;
-webkit-appearance: none;
}
.btn-secondary:active { background: var(–ink); color: #f2ede4; }

.btn-danger {
background: rgba(193,68,14,0.1);
color: var(–accent);
border: 1px solid rgba(193,68,14,0.3);
padding: 8px 14px;
font-family: ‘Bebas Neue’, cursive;
font-size: 12px;
letter-spacing: 1.5px;
cursor: pointer;
border-radius: 0;
-webkit-appearance: none;
}
.btn-danger:active { background: var(–accent); color: #fff; }

/* ===================== RESULT LINES ===================== */
.result-block {
background: var(–surface);
border: 1px solid var(–border);
padding: 14px;
margin-bottom: 12px;
}

.result-line {
display: flex;
justify-content: space-between;
align-items: center;
padding: 7px 0;
border-bottom: 1px dashed var(–border);
}
.result-line:last-child { border-bottom: none; }

.result-label { font-size: 9px; text-transform: uppercase; letter-spacing: 1px; color: var(–muted); }
.result-value { font-size: 14px; font-weight: 600; }

/* ===================== DESGLOSE ===================== */
.desglose-row {
display: flex;
align-items: center;
gap: 8px;
padding: 5px 0;
font-size: 11px;
}
.d-color { width: 8px; height: 8px; flex-shrink: 0; }
.d-name { flex: 1; color: var(–muted); }
.d-pct { width: 36px; text-align: right; font-weight: 600; }
.d-amt { width: 72px; text-align: right; }

.mini-bar { height: 3px; background: var(–border); margin: 2px 0 5px; overflow: hidden; }
.mini-fill { height: 100%; transition: width 0.5s; }

/* ===================== SLIDER ===================== */
.slider-group { margin: 10px 0; }
.slider-labels {
display: flex;
justify-content: space-between;
font-size: 9px;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 1px;
margin-bottom: 6px;
}
.slider-labels span { color: var(–ink); font-weight: 600; }

input[type=“range”] {
width: 100%;
accent-color: var(–accent);
cursor: pointer;
}

/* ===================== TOGGLE ===================== */
.toggle-row {
display: flex;
align-items: center;
justify-content: space-between;
padding: 8px 0;
font-size: 10px;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 1px;
border-bottom: 1px dashed var(–border);
}
.toggle-row:last-child { border-bottom: none; }

.toggle-sw { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
.toggle-sw input { opacity: 0; width: 0; height: 0; }
.toggle-track {
position: absolute; inset: 0;
background: var(–border);
cursor: pointer;
transition: 0.2s;
}
.toggle-track::before {
content: ‘’;
position: absolute;
width: 14px; height: 14px;
left: 3px; top: 3px;
background: #fff;
transition: 0.2s;
}
.toggle-sw input:checked + .toggle-track { background: var(–green); }
.toggle-sw input:checked + .toggle-track::before { transform: translateX(16px); }

/* ===================== DASHBOARD STATS ===================== */
.stats-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 8px;
margin-bottom: 12px;
}

.stat-card {
background: var(–surface);
border: 1px solid var(–border);
padding: 14px;
position: relative;
overflow: hidden;
}

.stat-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 3px;
}
.stat-card.sg::before { background: var(–green); }
.stat-card.sr::before { background: var(–red); }
.stat-card.sy::before { background: var(–yellow); }
.stat-card.sb::before { background: var(–blue); }
.stat-card.si::before { background: var(–ink); }

.stat-label { font-size: 8px; text-transform: uppercase; letter-spacing: 1.5px; color: var(–muted); margin-bottom: 5px; }
.stat-val { font-family: ‘Bebas Neue’, cursive; font-size: 28px; line-height: 1; color: var(–ink); }
.stat-sub { font-size: 9px; color: var(–muted); margin-top: 2px; }

/* ===================== HISTORIAL LIST ===================== */
.h-item {
background: var(–surface);
border: 1px solid var(–border);
border-left: 4px solid var(–border);
padding: 12px 14px;
margin-bottom: 8px;
cursor: pointer;
transition: border-left-color 0.15s;
display: block;
width: 100%;
text-align: left;
}
.h-item.rentable { border-left-color: var(–green); }
.h-item.warning { border-left-color: var(–yellow); }
.h-item.perdida { border-left-color: var(–red); }
.h-item:active { opacity: 0.85; }

.h-item-top {
display: flex;
justify-content: space-between;
align-items: flex-start;
margin-bottom: 6px;
}

.h-vehiculo { font-weight: 600; font-size: 13px; line-height: 1.2; }
.h-meta { font-size: 9px; color: var(–muted); margin-top: 2px; }

.h-margen-pill {
font-family: ‘Bebas Neue’, cursive;
font-size: 18px;
letter-spacing: 1px;
line-height: 1;
text-align: right;
flex-shrink: 0;
margin-left: 8px;
}
.h-margen-pill.pos { color: var(–green); }
.h-margen-pill.mid { color: var(–yellow); }
.h-margen-pill.neg { color: var(–red); }

.h-item-bottom {
display: flex;
justify-content: space-between;
font-size: 10px;
color: var(–muted);
}

.h-item-bottom span { color: var(–ink); font-weight: 500; }

/* ===================== DETAIL MODAL ===================== */
.modal-overlay {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.6);
z-index: 500;
display: none;
align-items: flex-end;
justify-content: center;
}
.modal-overlay.open { display: flex; }

.modal-sheet {
width: 100%;
max-width: 480px;
background: var(–bg);
border-top: 3px solid var(–accent);
max-height: 90dvh;
overflow-y: auto;
animation: sheetUp 0.3s ease;
}

@keyframes sheetUp {
from { transform: translateY(40px); opacity: 0; }
to { transform: translateY(0); opacity: 1; }
}

.modal-header {
background: var(–ink);
padding: 14px 16px;
display: flex;
justify-content: space-between;
align-items: center;
}

.modal-title {
font-family: ‘Bebas Neue’, cursive;
font-size: 18px;
letter-spacing: 2px;
color: #f2ede4;
}

.modal-close {
background: transparent;
border: 1px solid #444;
color: #888;
font-size: 18px;
width: 32px; height: 32px;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
border-radius: 0;
line-height: 1;
}
.modal-close:active { background: var(–accent); color: #fff; border-color: var(–accent); }

.modal-body { padding: 16px; }

/* BIG MARGEN DISPLAY */
.big-margen {
text-align: center;
padding: 20px 16px;
margin-bottom: 12px;
border: 2px solid var(–border);
}
.big-margen.rentable { border-color: var(–green); background: rgba(26,107,60,0.05); }
.big-margen.warning { border-color: var(–yellow); background: rgba(201,138,16,0.07); }
.big-margen.perdida { border-color: var(–red); background: rgba(193,68,14,0.05); }

.big-margen-num {
font-family: ‘Bebas Neue’, cursive;
font-size: 64px;
line-height: 1;
letter-spacing: 2px;
}
.rentable .big-margen-num { color: var(–green); }
.warning .big-margen-num { color: var(–yellow); }
.perdida .big-margen-num { color: var(–red); }

.big-margen-label {
font-size: 9px;
text-transform: uppercase;
letter-spacing: 2px;
color: var(–muted);
margin-top: 2px;
}

.big-margen-status {
font-family: ‘Bebas Neue’, cursive;
font-size: 14px;
letter-spacing: 2px;
margin-top: 6px;
}
.rentable .big-margen-status { color: var(–green); }
.warning .big-margen-status { color: var(–yellow); }
.perdida .big-margen-status { color: var(–red); }

/* DATA ROWS IN DETAIL */
.detail-row {
display: flex;
justify-content: space-between;
align-items: center;
padding: 9px 0;
border-bottom: 1px dashed var(–border);
font-size: 12px;
}
.detail-row:last-child { border-bottom: none; }
.dr-label { color: var(–muted); font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
.dr-value { font-weight: 600; }

/* ===================== FILTER BAR ===================== */
.filter-bar {
display: flex;
gap: 8px;
margin-bottom: 12px;
}

.filter-input {
flex: 1;
background: var(–surface);
border: 1px solid var(–border);
border-bottom: 2px solid var(–ink);
padding: 8px 10px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 12px;
color: var(–ink);
outline: none;
border-radius: 0;
}
.filter-input:focus { border-bottom-color: var(–accent); }

.filter-select {
background: var(–surface);
border: 1px solid var(–border);
border-bottom: 2px solid var(–ink);
padding: 8px 10px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 11px;
color: var(–ink);
outline: none;
-webkit-appearance: none;
border-radius: 0;
min-width: 90px;
}

/* ===================== ANALYSIS SECTION ===================== */
.analysis-block {
background: var(–surface);
border: 1px solid var(–border);
padding: 14px;
margin-bottom: 12px;
}

.rank-item {
display: flex;
align-items: center;
gap: 10px;
padding: 8px 0;
border-bottom: 1px dashed var(–border);
}
.rank-item:last-child { border-bottom: none; }

.rank-num {
font-family: ‘Bebas Neue’, cursive;
font-size: 20px;
color: var(–border);
width: 20px;
flex-shrink: 0;
}

.rank-info { flex: 1; min-width: 0; }
.rank-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rank-client { font-size: 9px; color: var(–muted); }

.rank-margen {
font-family: ‘Bebas Neue’, cursive;
font-size: 22px;
flex-shrink: 0;
letter-spacing: 1px;
}
.rank-margen.pos { color: var(–green); }
.rank-margen.mid { color: var(–yellow); }
.rank-margen.neg { color: var(–red); }

/* ===================== COTIZACIÓN ===================== */
.cot-preview {
background: var(–surface);
border: 2px solid var(–ink);
margin-bottom: 12px;
overflow: hidden;
}

.cot-header-bar {
background: var(–ink);
padding: 14px 16px;
}

.cot-brand-big {
font-family: ‘Bebas Neue’, cursive;
font-size: 20px;
letter-spacing: 3px;
color: #f2ede4;
}
.cot-brand-big span { color: var(–accent); }

.cot-num-line {
display: flex;
justify-content: space-between;
align-items: center;
margin-top: 8px;
}

.cot-num-badge {
font-family: ‘Bebas Neue’, cursive;
font-size: 16px;
color: var(–accent);
letter-spacing: 2px;
}

.cot-date-small { font-size: 9px; color: #777; }

.cot-body-pad { padding: 14px 16px; }

.cot-client-info {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 12px;
margin-bottom: 12px;
padding-bottom: 12px;
border-bottom: 1px solid var(–border);
}

.cot-ci-label { font-size: 8px; text-transform: uppercase; letter-spacing: 1.5px; color: var(–muted); margin-bottom: 3px; }
.cot-ci-val { font-size: 12px; font-weight: 500; }

.cot-table {
width: 100%;
border-collapse: collapse;
font-size: 11px;
margin-bottom: 12px;
}
.cot-table th {
background: var(–surface2);
font-size: 8px;
text-transform: uppercase;
letter-spacing: 1px;
color: var(–muted);
padding: 6px 8px;
text-align: left;
border-bottom: 1px solid var(–border);
}
.cot-table th:not(:first-child) { text-align: right; }
.cot-table td {
padding: 7px 8px;
border-bottom: 1px dashed var(–border);
vertical-align: top;
}
.cot-table td:not(:first-child) { text-align: right; }
.cot-table tr:last-child td { border-bottom: none; }

.cot-totals { border-top: 2px solid var(–ink); padding-top: 10px; }
.cot-total-row {
display: flex;
justify-content: space-between;
padding: 4px 0;
font-size: 11px;
}
.cot-tl { color: var(–muted); font-size: 9px; text-transform: uppercase; letter-spacing: 1px; }
.cot-tv { font-weight: 600; }
.cot-total-grand {
border-top: 1px solid var(–border);
margin-top: 6px;
padding-top: 8px;
font-size: 14px;
}
.cot-total-grand .cot-tv { color: var(–accent); font-size: 18px; }

.cot-footer-bar {
background: var(–surface2);
border-top: 1px solid var(–border);
padding: 8px 16px;
display: flex;
justify-content: space-between;
font-size: 9px;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 1px;
}

/* Validity pills */
.validity-row { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
.val-pill {
padding: 5px 10px;
border: 1px solid var(–border);
font-size: 9px;
text-transform: uppercase;
letter-spacing: 1px;
cursor: pointer;
color: var(–muted);
background: var(–surface);
border-radius: 0;
-webkit-appearance: none;
}
.val-pill.sel { background: var(–ink); border-color: var(–ink); color: #f2ede4; }

/* Partidas */
.partida-row {
display: grid;
grid-template-columns: 1fr 60px 75px 24px;
gap: 6px;
align-items: center;
padding: 6px 0;
border-bottom: 1px dashed var(–border);
}
.partida-row:last-child { border-bottom: none; }

.nota-input {
width: 100%;
background: var(–bg);
border: 1px solid var(–border);
border-bottom: 2px solid var(–ink);
padding: 8px 10px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 12px;
color: var(–ink);
outline: none;
resize: vertical;
min-height: 60px;
border-radius: 0;
}
.nota-input:focus { border-bottom-color: var(–accent); }

/* ===================== EMPTY STATE ===================== */
.empty-state {
text-align: center;
padding: 40px 20px;
}
.empty-icon { font-size: 36px; margin-bottom: 10px; }
.empty-text { font-size: 9px; text-transform: uppercase; letter-spacing: 2px; color: var(–muted); }

/* ===================== CONFIRM DIALOG ===================== */
.confirm-overlay {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.7);
z-index: 600;
display: none;
align-items: center;
justify-content: center;
padding: 16px;
}
.confirm-overlay.open { display: flex; }

.confirm-box {
background: var(–surface);
border: 2px solid var(–ink);
padding: 24px 20px;
width: 100%;
max-width: 320px;
text-align: center;
animation: sheetUp 0.2s ease;
}

.confirm-title {
font-family: ‘Bebas Neue’, cursive;
font-size: 22px;
letter-spacing: 2px;
margin-bottom: 8px;
}
.confirm-desc { font-size: 11px; color: var(–muted); margin-bottom: 20px; line-height: 1.5; }
.confirm-btns { display: flex; gap: 8px; }

/* ===================== PRINT ===================== */
@media print {
.app-header, .bottom-nav, .card:not(.print-only), .btn-row, .btn-danger { display: none !important; }
.cot-preview { border: none; }
body { background: white; }
}

/* ===================== ANIMATIONS ===================== */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(8px); }
to { opacity: 1; transform: translateY(0); }
}

.fade-up { animation: fadeUp 0.3s ease both; }

.h-item:nth-child(1) { animation-delay: 0s; }
.h-item:nth-child(2) { animation-delay: 0.04s; }
