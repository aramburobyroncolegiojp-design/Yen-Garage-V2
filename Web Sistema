<script>
// ============================================================
// DATA STORE
// ============================================================
let trabajosDB = JSON.parse(localStorage.getItem('yg_v3_trabajos') || '[]');
let cotizacionesDB = JSON.parse(localStorage.getItem('yg_v3_cots') || '[]');
let validezSel = '7 días';
let confirmCallback = null;
let currentDetailId = null;

function saveDB() {
  localStorage.setItem('yg_v3_trabajos', JSON.stringify(trabajosDB));
  localStorage.setItem('yg_v3_cots', JSON.stringify(cotizacionesDB));
  updateBadges();
}

function updateBadges() {
  const bh = document.getElementById('badge-hist');
  const bc = document.getElementById('badge-cot');
  const total = trabajosDB.length + cotizacionesDB.length;
  bh.textContent = trabajosDB.length;
  bh.style.display = trabajosDB.length > 0 ? 'block' : 'none';
  bc.textContent = cotizacionesDB.length;
  bc.style.display = cotizacionesDB.length > 0 ? 'block' : 'none';
}

// ============================================================
// NAVIGATION
// ============================================================
function goPage(id, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  btn.classList.add('active');
  document.querySelector('.scroll-area').scrollTop = 0;
  if (id === 'historial') renderDashboard();
}

// ============================================================
// INIT
// ============================================================
window.onload = function() {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('r-fecha').value = today;
  document.getElementById('c-fecha').value = today;
  autoCotNum();
  updateBadges();
  renderCot();
};

// ============================================================
// UTILS
// ============================================================
function fmt(n) {
  const v = parseFloat(n) || 0;
  return '$' + v.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtShort(n) {
  const v = parseFloat(n) || 0;
  if (v >= 1000000) return '$' + (v/1000000).toFixed(1) + 'M';
  if (v >= 1000) return '$' + (v/1000).toFixed(1) + 'k';
  return fmt(v);
}

function margenClass(m) {
  return m >= 25 ? 'rentable' : m >= 10 ? 'warning' : 'perdida';
}

function margenLabel(m) {
  return m >= 25 ? 'RENTABLE' : m >= 10 ? 'MARGEN BAJO' : 'PERDIDA';
}

// ============================================================
// COST ROW LOGIC
// ============================================================
function calcRow(input) {
  const row = input.closest('.cost-row');
  const ins = row.querySelectorAll('.cost-input');
  const p = parseFloat(ins[0]?.value) || 0;
  const q = parseFloat(ins[1]?.value) || 0;
  const sub = row.querySelector('.cost-subtotal');
  if (sub) sub.textContent = fmt(p * q);
}

function sumSection(id) {
  const el = document.getElementById(id);
  if (!el) return 0;
  let t = 0;
  el.querySelectorAll('.cost-row').forEach(row => {
    const ins = row.querySelectorAll('.cost-input');
    t += (parseFloat(ins[0]?.value) || 0) * (parseFloat(ins[1]?.value) || 1);
  });
  return t;
}

function addRow(containerId) {
  const el = document.getElementById(containerId);
  const row = document.createElement('div');
  row.className = 'cost-row fade-up';
  row.innerHTML = `
    <input class="cost-input" placeholder="Nombre" style="text-align:left;font-size:11px">
    <input class="cost-input" placeholder="0" oninput="calcRow(this);calcular()">
    <input class="cost-input" placeholder="1" value="1" oninput="calcRow(this);calcular()">
    <button class="del-btn" onclick="delRow(this)">×</button>`;
  el.appendChild(row);
}

function delRow(btn) {
  btn.closest('.cost-row').remove();
  calcular();
}

// ============================================================
// RENTABILIDAD CALC
// ============================================================
function calcular() {
  const mat = sumSection('mat-pintura') + sumSection('mat-prep') + sumSection('mat-otros');
  const mo = sumSection('mano-obra');
  const ind = sumSection('indirectos');
  const total = mat + mo + ind;
  const margen = parseInt(document.getElementById('r-margenSlider').value) / 100;
  const prio = parseFloat(document.getElementById('r-prioridad').value) || 1;

  document.getElementById('r-factorPrio').textContent = '×' + prio.toFixed(2);

  const precioBase = total > 0 ? total / (1 - margen) : 0;
  const precioSug = precioBase * prio;

  document.getElementById('r-costoTotal').textContent = fmt(total);
  document.getElementById('r-precioSug').textContent = precioSug > 0
    ? precioSug.toLocaleString('es-MX', { minimumFractionDigits: 2 }) : '0.00';

  if (total > 0) {
    const pM = Math.round(mat/total*100);
    const pMO = Math.round(mo/total*100);
    const pI = Math.round(ind/total*100);
    document.getElementById('r-pctMat').textContent = pM + '%';
    document.getElementById('r-pctMO').textContent = pMO + '%';
    document.getElementById('r-pctInd').textContent = pI + '%';
    document.getElementById('r-barMat').style.width = pM + '%';
    document.getElementById('r-barMO').style.width = pMO + '%';
    document.getElementById('r-barInd').style.width = pI + '%';
  }
  document.getElementById('r-amtMat').textContent = fmt(mat);
  document.getElementById('r-amtMO').textContent = fmt(mo);
  document.getElementById('r-amtInd').textContent = fmt(ind);

  calcularVeredicto();
}

function updateMargen() {
  document.getElementById('r-margenDisplay').textContent = document.getElementById('r-margenSlider').value + '%';
}

function calcularVeredicto() {
  const costoRaw = document.getElementById('r-costoTotal').textContent.replace(/[$,]/g,'');
  const costo = parseFloat(costoRaw) || 0;
  const cobrado = parseFloat(document.getElementById('r-precioCobrado').value) || 0;
  const ganancia = cobrado - costo;
  const margenReal = cobrado > 0 ? (ganancia / cobrado) * 100 : 0;

  document.getElementById('r-gananciaReal').textContent = fmt(ganancia);
  document.getElementById('r-gananciaReal').style.color = ganancia >= 0 ? 'var(--green)' : 'var(--red)';

  const bar = document.getElementById('r-margenBar');
  bar.style.width = Math.max(0, Math.min(100, margenReal)) + '%';
  document.getElementById('r-margenPct').textContent = margenReal.toFixed(1) + '%';
  bar.className = 'margen-bar' + (margenReal >= 25 ? '' : margenReal >= 10 ? ' w' : ' d');

  const v = document.getElementById('r-veredicto');
  if (!costo && !cobrado) {
    v.className = 'veredicto';
    v.innerHTML = `<div class="v-title">INGRESA LOS DATOS</div><div class="v-sub">Llena materiales, mano de obra y precio</div>`;
    return;
  }
  if (!cobrado) {
    v.className = 'veredicto warning';
    v.innerHTML = `<div class="v-title">PRECIO SUGERIDO LISTO</div><div class="v-sub">Ingresa el precio que cobrarás</div>`;
    return;
  }
  const cls = margenClass(margenReal);
  const icons = { rentable: '', warning: '', perdida: '' };
  const titles = { rentable: 'TRABAJO RENTABLE', warning: 'MARGEN BAJO', perdida: margenReal >= 0 ? 'RIESGO DE PÉRDIDA' : 'TRABAJO EN PÉRDIDA' };
  const subs = {
    rentable: `Margen ${margenReal.toFixed(1)}% · Ganancia: ${fmt(ganancia)}`,
    warning: `Margen ${margenReal.toFixed(1)}% · Considera ajustar precio`,
    perdida: margenReal >= 0 ? `Margen ${margenReal.toFixed(1)}% · Casi sin ganancia` : `Pérdida de ${fmt(Math.abs(ganancia))}`
  };
  v.className = 'veredicto ' + cls;
  v.innerHTML = `<div class="v-title">${titles[cls]}</div><div class="v-sub">${subs[cls]}</div>`;
}

// ============================================================
// GUARDAR TRABAJO (snapshot completo)
// ============================================================
function guardarTrabajo() {
  const vehiculo = document.getElementById('r-vehiculo').value.trim();
  const tipo = document.getElementById('r-tipo').value;
  if (!vehiculo || !tipo) {
    alert(' Completa Vehículo y Tipo de trabajo antes de guardar.');
    return;
  }

  const mat = sumSection('mat-pintura') + sumSection('mat-prep') + sumSection('mat-otros');
  const mo = sumSection('mano-obra');
  const ind = sumSection('indirectos');
  const costoTotal = mat + mo + ind;
  const cobrado = parseFloat(document.getElementById('r-precioCobrado').value) || 0;
  const ganancia = cobrado - costoTotal;
  const margenReal = cobrado > 0 ? (ganancia / cobrado) * 100 : 0;

  // Snapshot completo — no se modifica después
  const snapshot = {
    id: Date.now(),
    ts: new Date().toLocaleString('es-MX'),
    // Identidad
    vehiculo,
    tipo,
    cliente: document.getElementById('r-cliente').value.trim() || '—',
    folio: document.getElementById('r-folio').value.trim() || ('OT-' + Date.now()),
    fecha: document.getElementById('r-fecha').value,
    notas: document.getElementById('r-notas').value,
    // Financiero (snapshot fijo)
    mat, mo, ind,
    costoTotal,
    cobrado,
    ganancia,
    margenReal,
    // Factor
    prio: parseFloat(document.getElementById('r-prioridad').value) || 1
  };

  trabajosDB.unshift(snapshot);
  saveDB();
  alert(` Guardado: ${vehiculo}\nGanancia: ${fmt(ganancia)} (${margenReal.toFixed(1)}%)`);
}

function limpiarRegistro() {
  if (!confirm('¿Limpiar todos los datos del formulario?')) return;
  ['r-vehiculo','r-cliente','r-folio','r-notas','r-precioCobrado'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('r-tipo').value = '';
  document.getElementById('r-prioridad').value = '1';
  document.getElementById('r-fecha').value = new Date().toISOString().split('T')[0];
  document.querySelectorAll('#page-registro .cost-input').forEach(i => { i.value = ''; });
  calcular();
}

function irACotizacion() {
  // Transferir datos al módulo cotización
  const v = document.getElementById('r-vehiculo').value;
  const c = document.getElementById('r-cliente').value;
  const tipo = document.getElementById('r-tipo').value;
  const cobrado = document.getElementById('r-precioCobrado').value;
  if (v) document.getElementById('c-vehiculo').value = v;
  if (c) document.getElementById('c-cliente').value = c;
  if (tipo && cobrado) {
    const rows = document.getElementById('cot-partidas').querySelectorAll('.partida-row');
    if (rows.length > 0) {
      const ins = rows[0].querySelectorAll('.cost-input');
      ins[0].value = tipo;
      ins[1].value = '1';
      ins[2].value = cobrado;
    }
  }
  renderCot();
  goPage('cotizacion', document.querySelectorAll('.nav-btn')[1]);
}

// ============================================================
// COTIZACIÓN
// ============================================================
function autoCotNum() {
  const num = cotizacionesDB.length + 1;
  document.getElementById('c-numero').value = 'COT-' + new Date().getFullYear() + '-' + String(num).padStart(3,'0');
}

function setValidity(btn, val) {
  document.querySelectorAll('.val-pill').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  validezSel = val;
  renderCot();
}

function addPartida() {
  const container = document.getElementById('cot-partidas');
  const row = document.createElement('div');
  row.className = 'partida-row fade-up';
  row.innerHTML = `
    <input class="cost-input" placeholder="Descripción..." style="text-align:left;font-size:11px" oninput="renderCot()">
    <input class="cost-input" placeholder="1" value="1" oninput="renderCot()">
    <input class="cost-input" placeholder="0.00" oninput="renderCot()">
    <button class="del-btn" onclick="delPartida(this)">×</button>`;
  container.appendChild(row);
  renderCot();
}

function delPartida(btn) {
  btn.closest('.partida-row').remove();
  renderCot();
}

function renderCot() {
  const numero = document.getElementById('c-numero').value || 'COT-001';
  const fecha = document.getElementById('c-fecha').value;
  const cliente = document.getElementById('c-cliente').value;
  const tel = document.getElementById('c-tel').value;
  const vehiculo = document.getElementById('c-vehiculo').value;
  const color = document.getElementById('c-color').value;
  const iva = document.getElementById('c-iva').checked;
  const anticipo = parseInt(document.getElementById('c-anticipo').value) || 0;
  const tiempo = document.getElementById('c-tiempo').value;
  const notas = document.getElementById('c-notas').value;

  document.getElementById('cd-numero').textContent = numero;
  document.getElementById('cd-footer-num').textContent = numero;
  document.getElementById('cd-validez').textContent = validezSel;
  document.getElementById('cd-fecha').textContent = fecha
    ? new Date(fecha + 'T12:00:00').toLocaleDateString('es-MX',{day:'2-digit',month:'short',year:'numeric'}) : '—';
  document.getElementById('cd-cliente').textContent = cliente || '—';
  document.getElementById('cd-tel').textContent = tel;
  document.getElementById('cd-vehiculo').textContent = vehiculo || '—';
  document.getElementById('cd-color').textContent = color ? 'Color: ' + color : '';

  const rows = document.getElementById('cot-partidas').querySelectorAll('.partida-row');
  let subtotal = 0;
  const partidas = [];
  rows.forEach(row => {
    const ins = row.querySelectorAll('.cost-input');
    const desc = ins[0]?.value || '';
    const cant = parseFloat(ins[1]?.value) || 1;
    const unit = parseFloat(ins[2]?.value) || 0;
    if (desc || unit > 0) { partidas.push({desc,cant,unit,total:cant*unit}); subtotal += cant*unit; }
  });

  const tableEl = document.getElementById('cd-table');
  const totalsEl = document.getElementById('cd-totals');

  if (!partidas.length) {
    tableEl.innerHTML = '<div style="text-align:center;padding:20px;font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--muted)">Agrega partidas</div>';
    totalsEl.style.display = 'none';
    return;
  }

  tableEl.innerHTML = `<table class="cot-table">
    <thead><tr><th>#</th><th>Servicio</th><th>Cant</th><th>Precio</th><th>Total</th></tr></thead>
    <tbody>${partidas.map((p,i)=>`<tr><td style="color:var(--muted)">${i+1}</td><td>${p.desc||'—'}</td><td>${p.cant}</td><td>${fmt(p.unit)}</td><td>${fmt(p.total)}</td></tr>`).join('')}</tbody>
  </table>`;

  totalsEl.style.display = 'block';
  const ivaAmt = iva ? subtotal * 0.16 : 0;
  const total = subtotal + ivaAmt;
  const antAmt = anticipo > 0 ? total * anticipo / 100 : 0;

  document.getElementById('cd-subtotal').textContent = fmt(subtotal);
  document.getElementById('cd-iva-row').style.display = iva ? 'flex' : 'none';
  document.getElementById('cd-iva').textContent = fmt(ivaAmt);
  document.getElementById('cd-ant-row').style.display = anticipo > 0 ? 'flex' : 'none';
  document.getElementById('cd-ant').textContent = fmt(antAmt) + ' (' + anticipo + '%)';
  document.getElementById('cd-total').textContent = fmt(total);

  const tEl = document.getElementById('cd-tiempo');
  tEl.style.display = tiempo ? 'block' : 'none';
  document.getElementById('cd-tiempo-val').textContent = tiempo;

  const nEl = document.getElementById('cd-notas-wrap');
  nEl.style.display = notas ? 'block' : 'none';
  document.getElementById('cd-notas').textContent = notas;
}

function guardarCotizacion() {
  const rows = document.getElementById('cot-partidas').querySelectorAll('.partida-row');
  let subtotal = 0;
  rows.forEach(row => {
    const ins = row.querySelectorAll('.cost-input');
    subtotal += (parseFloat(ins[1]?.value)||1) * (parseFloat(ins[2]?.value)||0);
  });
  const iva = document.getElementById('c-iva').checked ? subtotal * 0.16 : 0;
  const total = subtotal + iva;

  cotizacionesDB.unshift({
    id: Date.now(),
    numero: document.getElementById('c-numero').value || 'COT-001',
    cliente: document.getElementById('c-cliente').value || '—',
    vehiculo: document.getElementById('c-vehiculo').value || '—',
    total, fecha: document.getElementById('c-fecha').value,
    ts: new Date().toLocaleString('es-MX')
  });

  saveDB();
  autoCotNum();
  alert(' Cotización guardada · ' + fmt(total));
}

// ============================================================
// HISTORIAL / DASHBOARD
// ============================================================
function renderDashboard() {
  const n = trabajosDB.length;
  const ganancia = trabajosDB.reduce((s,t) => s + t.ganancia, 0);
  const factura = trabajosDB.reduce((s,t) => s + t.cobrado, 0);
  const margenProm = n > 0 ? trabajosDB.reduce((s,t) => s + t.margenReal, 0) / n : 0;
  const rentables = trabajosDB.filter(t => t.margenReal >= 25).length;

  document.getElementById('ds-ganancia').textContent = fmtShort(ganancia);
  document.getElementById('ds-factura').textContent = fmtShort(factura);
  document.getElementById('ds-margen').textContent = margenProm.toFixed(1) + '%';
  document.getElementById('ds-margen-sub').textContent = margenProm >= 25 ? 'saludable' : margenProm >= 10 ? 'zona gris' : n > 0 ? 'critico' : 'sin datos';
  document.getElementById('ds-count').textContent = n;
  document.getElementById('ds-count-sub').textContent = rentables + ' rentables · ' + cotizacionesDB.length + ' cots';

  // Análisis nivel 2
  const ab = document.getElementById('analysis-block');
  if (n >= 2) {
    ab.style.display = 'block';
    const sorted = [...trabajosDB].sort((a,b) => b.margenReal - a.margenReal);
    const top3 = sorted.slice(0,3);
    const bot3 = sorted.slice(-3).reverse();
    renderRank('top-rentables', top3, true);
    renderRank('top-perdidas', bot3, false);
  } else {
    ab.style.display = 'none';
  }

  renderHistorial();
  renderCotizacionesList();
}

function renderRank(containerId, items, isTop) {
  const el = document.getElementById(containerId);
  if (!items.length) { el.innerHTML = '<div style="font-size:10px;color:var(--muted);padding:8px 0">Sin datos</div>'; return; }
  el.innerHTML = items.map((t, i) => {
    const mc = margenClass(t.margenReal);
    const mpClass = mc === 'rentable' ? 'pos' : mc === 'warning' ? 'mid' : 'neg';
    return `<div class="rank-item">
      <div class="rank-num">${i+1}</div>
      <div class="rank-info">
        <div class="rank-name">${t.vehiculo}</div>
        <div class="rank-client">${t.tipo} · ${t.cliente}</div>
      </div>
      <div class="rank-margen ${mpClass}">${t.margenReal.toFixed(0)}%</div>
    </div>`;
  }).join('');
}

function renderHistorial() {
  const el = document.getElementById('lista-trabajos');
  const q = (document.getElementById('h-search')?.value || '').toLowerCase();
  const f = document.getElementById('h-filter')?.value || 'todos';

  let lista = trabajosDB.filter(t => {
    const str = `${t.vehiculo} ${t.cliente} ${t.tipo} ${t.folio}`.toLowerCase();
    if (!str.includes(q)) return false;
    const mc = margenClass(t.margenReal);
    if (f !== 'todos' && mc !== f) return false;
    return true;
  });

  if (!lista.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-text">Sin resultados</div></div>`;
    return;
  }

  el.innerHTML = lista.map(t => {
    const mc = margenClass(t.margenReal);
    const mpClass = mc === 'rentable' ? 'pos' : mc === 'warning' ? 'mid' : 'neg';
    return `<button class="h-item ${mc} fade-up" onclick="openDetail(${t.id})">
      <div class="h-item-top">
        <div>
          <div class="h-vehiculo">${t.vehiculo}</div>
          <div class="h-meta">${t.tipo} · ${t.cliente}</div>
        </div>
        <div class="h-margen-pill ${mpClass}">${t.margenReal.toFixed(1)}%</div>
      </div>
      <div class="h-item-bottom">
        <div>Cobrado: <span>${fmt(t.cobrado)}</span></div>
        <div>Ganancia: <span style="color:${t.ganancia>=0?'var(--green)':'var(--red)'}">${fmt(t.ganancia)}</span></div>
        <div>${t.fecha || '—'}</div>
      </div>
    </button>`;
  }).join('');
}

function renderCotizacionesList() {
  const el = document.getElementById('lista-cotizaciones');
  if (!cotizacionesDB.length) {
    el.innerHTML = `<div class="empty-state"><div class="empty-text">No hay cotizaciones</div></div>`;
    return;
  }
  el.innerHTML = cotizacionesDB.map(c => `
    <div class="h-item fade-up" style="cursor:default;border-left-color:var(--blue)">
      <div class="h-item-top">
        <div>
          <div class="h-vehiculo" style="color:var(--blue)">${c.numero}</div>
          <div class="h-meta">${c.vehiculo} · ${c.cliente}</div>
        </div>
        <div style="font-family:'Bebas Neue',cursive;font-size:18px;color:var(--ink)">${fmt(c.total)}</div>
      </div>
      <div class="h-item-bottom" style="justify-content:space-between">
        <div>${c.fecha || '—'}</div>
        <button class="btn-danger" style="padding:4px 10px;font-size:10px" onclick="confirmDelete('cot',${c.id})">ELIMINAR</button>
      </div>
    </div>`).join('');
}

// ============================================================
// DETAIL MODAL
// ============================================================
function openDetail(id) {
  const t = trabajosDB.find(x => x.id === id);
  if (!t) return;
  currentDetailId = id;

  const mc = margenClass(t.margenReal);
  const statusLabel = margenLabel(t.margenReal);

  document.getElementById('modal-title').textContent = t.vehiculo;
  document.getElementById('modal-body').innerHTML = `
    <div class="big-margen ${mc}">
      <div class="big-margen-num">${t.margenReal.toFixed(1)}%</div>
      <div class="big-margen-label">Margen sobre precio cobrado</div>
      <div class="big-margen-status">${statusLabel}</div>
    </div>

    <div class="result-block">
      <div class="section-title" style="font-size:14px">Resumen</div>
      <div class="detail-row"><div class="dr-label">Vehículo</div><div class="dr-value">${t.vehiculo}</div></div>
      <div class="detail-row"><div class="dr-label">Tipo de trabajo</div><div class="dr-value">${t.tipo}</div></div>
      <div class="detail-row"><div class="dr-label">Cliente</div><div class="dr-value">${t.cliente}</div></div>
      <div class="detail-row"><div class="dr-label">Folio</div><div class="dr-value" style="font-size:11px;color:var(--muted)">${t.folio}</div></div>
      <div class="detail-row"><div class="dr-label">Fecha</div><div class="dr-value" style="font-size:12px">${t.fecha || '—'}</div></div>
    </div>

    <div class="result-block">
      <div class="section-title" style="font-size:14px">Financiero</div>
      <div class="detail-row">
        <div class="dr-label">Ingresos (cobrado)</div>
        <div class="dr-value" style="color:var(--blue)">${fmt(t.cobrado)}</div>
      </div>
      <div class="detail-row">
        <div class="dr-label">Costo total real</div>
        <div class="dr-value" style="color:var(--muted)">${fmt(t.costoTotal)}</div>
      </div>
      <div class="detail-row">
        <div class="dr-label">Utilidad / Ganancia</div>
        <div class="dr-value" style="color:${t.ganancia>=0?'var(--green)':'var(--red)'}">
          ${fmt(t.ganancia)}
        </div>
      </div>
      <div class="detail-row">
        <div class="dr-label">Margen</div>
        <div class="dr-value" style="font-size:20px;font-family:'Bebas Neue',cursive;color:${mc==='rentable'?'var(--green)':mc==='warning'?'var(--yellow)':'var(--red)'}">
          ${t.margenReal.toFixed(1)}%
        </div>
      </div>
    </div>

    <div class="result-block">
      <div class="section-title" style="font-size:14px">Desglose de costos</div>
      <div class="detail-row">
        <div class="dr-label">Materiales</div>
        <div class="dr-value">${fmt(t.mat)}</div>
      </div>
      <div class="detail-row">
        <div class="dr-label">Mano de obra</div>
        <div class="dr-value">${fmt(t.mo)}</div>
      </div>
      <div class="detail-row">
        <div class="dr-label">Indirectos / Extras</div>
        <div class="dr-value">${fmt(t.ind)}</div>
      </div>
      ${t.costoTotal > 0 ? `
      <div style="margin-top:10px">
        <div class="desglose-row"><div class="d-color" style="background:var(--accent)"></div><div class="d-name">Materiales</div><div class="d-pct">${Math.round(t.mat/t.costoTotal*100)}%</div></div>
        <div class="mini-bar"><div class="mini-fill" style="width:${Math.round(t.mat/t.costoTotal*100)}%;background:var(--accent)"></div></div>
        <div class="desglose-row"><div class="d-color" style="background:var(--blue)"></div><div class="d-name">Mano de obra</div><div class="d-pct">${Math.round(t.mo/t.costoTotal*100)}%</div></div>
        <div class="mini-bar"><div class="mini-fill" style="width:${Math.round(t.mo/t.costoTotal*100)}%;background:var(--blue)"></div></div>
        <div class="desglose-row"><div class="d-color" style="background:var(--muted)"></div><div class="d-name">Indirectos</div><div class="d-pct">${Math.round(t.ind/t.costoTotal*100)}%</div></div>
        <div class="mini-bar"><div class="mini-fill" style="width:${Math.round(t.ind/t.costoTotal*100)}%;background:var(--muted)"></div></div>
      </div>` : ''}
    </div>

    ${t.notas ? `<div style="background:var(--surface2);border-left:3px solid var(--accent);padding:10px 12px;font-size:11px;color:var(--muted);margin-bottom:12px">
      <div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--ink);margin-bottom:4px">Notas</div>
      ${t.notas}
    </div>` : ''}

    <div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:16px">
      Guardado: ${t.ts}
    </div>

    <button class="btn-danger" style="width:100%;padding:12px" onclick="confirmDelete('trabajo',${t.id})">
      ELIMINAR ESTE TRABAJO
    </button>
  `;

  document.getElementById('detailModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeDetail() {
  document.getElementById('detailModal').classList.remove('open');
  document.body.style.overflow = '';
  currentDetailId = null;
}

function closeDetailOnOverlay(e) {
  if (e.target === document.getElementById('detailModal')) closeDetail();
}

// ============================================================
// CONFIRM / DELETE
// ============================================================
function confirmDelete(type, id) {
  const labels = { trabajo: 'Eliminar trabajo', cot: 'Eliminar cotización' };
  document.getElementById('confirm-title').textContent = labels[type] || 'Confirmar eliminacion';
  document.getElementById('confirm-desc').textContent = 'Esta acción no se puede deshacer. El registro se eliminará permanentemente.';
  confirmCallback = () => doDelete(type, id);
  document.getElementById('confirmOverlay').classList.add('open');
}

function closeConfirm() {
  document.getElementById('confirmOverlay').classList.remove('open');
  confirmCallback = null;
}

function executeConfirm() {
  if (confirmCallback) confirmCallback();
  closeConfirm();
}

function doDelete(type, id) {
  if (type === 'trabajo') {
    trabajosDB = trabajosDB.filter(t => t.id !== id);
    closeDetail();
  } else if (type === 'cot') {
    cotizacionesDB = cotizacionesDB.filter(c => c.id !== id);
  }
  saveDB();
  renderDashboard();
}
</script>

</body>
</html>
